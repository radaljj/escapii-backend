# ================================================================
# ESCAPII BACKEND — Environment varijable
# ================================================================
# KORISCENJE:
#   1. Kopiraj ovaj fajl: cp .env.example .env
#   2. Popuni vrednosti u .env
#   3. NIKAD ne commituj .env na GitHub!
#
# Na Railway/Render: unesi ove vrednosti u Environment Variables panel
# ================================================================

# ----- BAZA PODATAKA -----
DB_URL=jdbc:postgresql://localhost:5432/escapii_db
DB_USERNAME=postgres
DB_PASSWORD=tvoja_lokalna_lozinka

# ----- EMAIL (Gmail SMTP) -----
# Koristicko ime Gmail naloga
MAIL_USERNAME=escapii@gmail.com
# App Password (ne tvoja gmail lozinka!)
# Napravi na: https://myaccount.google.com/apppasswords
# (treba ukljuciti 2FA, pa onda App password za "Mail")
MAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ----- ESCAPII KONFIGURACIJA -----
# Email adresa tima — prima sve nove uupite
TEAM_EMAIL=team@escapii.com

# WordPress sajt (CORS whitelist — samo ovaj domen moze da poziva API)
CORS_ALLOWED_ORIGIN=https://escapii.com

# Port (Railway automatski postavlja PORT env var)
PORT=8080
