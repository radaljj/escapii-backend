<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

  <!--
    AsyncRequestNotUsableException / Broken pipe su normalni disconnect eventi
    kada admin zatvori tab — ne predstavljaju pravi problem, samo zagađuju logove.
  -->
  <logger name="org.springframework.web.context.request.async" level="OFF"/>
  <logger name="org.apache.catalina.core.AsyncContextImpl" level="OFF"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
